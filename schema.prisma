datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── USER & PROPERTY ────────────────────────

model User {
  id          String @id @default(uuid())
  username    String
  aiApiKey      String?   // Encrypted API key (AES-256-GCM)
  aiProvider    String    @default("anthropic") // "anthropic" or "openrouter"

  memberships    PropertyMember[]
  invitations    PropertyInvitation[]
  tasks          Task[]
  harvestLogs    HarvestLog[]
  seedStartLogs  SeedStartLog[]
  journalEntries JournalEntry[]
  soilTests      SoilTest[]
  amendmentLogs  AmendmentLog[]
}

enum PropertyRole {
  OWNER
  MEMBER
}

model Property {
  id             String   @id @default(uuid())
  name           String
  acreage        Float
  hardinessZone  String   @default("3B")
  lastFrostDate  String   @default("05-21")
  firstFrostDate String   @default("09-12")
  timezone       String   @default("America/Regina")
  latitude       Float?
  longitude      Float?
  notes          String?
  aiSystemPrompt   String?   // Custom AI system prompt override
  weatherApiToken  String?   // Encrypted Tempest API token
  weatherStationId Int?      // Tempest station ID

  members        PropertyMember[]
  invitations    PropertyInvitation[]
  zones          PropertyZone[]
  waterSystems   WaterSystem[]
  animals        AnimalGroup[]
  compostBins    CompostBin[]
  calendarEvents CalendarEvent[]
  tasks          Task[]
  photos         Photo[]
  inventoryItems  InventoryItem[]
  seedInventory   SeedInventory[]
  seedStartLogs   SeedStartLog[]
  harvestLogs     HarvestLog[]
  journalEntries  JournalEntry[]
  soilTests       SoilTest[]
  amendmentLogs   AmendmentLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PropertyMember {
  id         String       @id @default(uuid())
  role       PropertyRole @default(MEMBER)

  user       User     @relation(fields: [userId], references: [id])
  userId     String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
}

model PropertyInvitation {
  id              String       @id @default(uuid())
  email           String
  property        Property     @relation(fields: [propertyId], references: [id])
  propertyId      String
  invitedBy       User         @relation(fields: [invitedByUserId], references: [id])
  invitedByUserId String
  token           String       @unique @default(uuid())
  role            PropertyRole @default(MEMBER)
  expiresAt       DateTime
  acceptedAt      DateTime?

  createdAt       DateTime     @default(now())

  @@unique([email, propertyId])
}

model PropertyZone {
  id          String           @id @default(uuid())
  name        String
  permZone    PermacultureZone
  description String?
  areaSqFt    Float?
  notes       String?

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  gardenBeds GardenBed[]
  photos     Photo[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum PermacultureZone {
  ZONE_0
  ZONE_1
  ZONE_2
  ZONE_3
  ZONE_4
  ZONE_5
}

// ─── GARDEN BEDS & PLANTINGS ────────────────

enum BedShape {
  RECTANGLE
  OVAL
}

enum BedType {
  RAISED
  IN_GROUND
  CONTAINER
}

model GardenBed {
  id       String @id @default(uuid())
  name     String
  widthFt  Int
  lengthFt Int
  shape    BedShape @default(RECTANGLE)
  bedType  BedType  @default(IN_GROUND)
  heightIn Int?
  soilType String?
  notes    String?

  zone   PropertyZone @relation(fields: [zoneId], references: [id])
  zoneId String

  squares        BedSquare[]
  plantings      Planting[]
  photos         Photo[]
  designHistory  BedDesignHistory[]
  chatSessions   AiChatSession[]
  soilTests      SoilTest[]
  amendmentLogs  AmendmentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BedDesignHistory {
  id              String    @id @default(uuid())
  bed             GardenBed @relation(fields: [bedId], references: [id])
  bedId           String
  year            Int
  season          Season    @default(SPRING)
  layoutJson      String    // JSON: [{row, col, plantId}]
  prompt          String    // User prompt that triggered this
  explanation     String?   // AI's design rationale
  successionNotes String?   // JSON: [{cells, timing, plantId}]
  acceptedAt      DateTime  @default(now())
}

model AiChatSession {
  id           String    @id @default(uuid())
  bed          GardenBed @relation(fields: [bedId], references: [id])
  bedId        String
  year         Int
  season       Season    @default(SPRING)
  messagesJson String    // JSON: [{role, content, layout?, explanation?, successionNotes?}]
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@unique([bedId, year, season])
}

model BedSquare {
  id         String @id @default(uuid())
  row        Int
  col        Int
  year       Int
  season     Season @default(SPRING)

  bed        GardenBed @relation(fields: [bedId], references: [id])
  bedId      String
  planting   Planting? @relation(fields: [plantingId], references: [id])
  plantingId String?

  notes String?

  @@unique([bedId, row, col, year, season])
}

enum Season {
  SPRING
  SUMMER
  FALL
}

model Planting {
  id            String @id @default(uuid())
  year          Int
  season        Season @default(SPRING)
  datePlanted   String?
  dateHarvested String?
  notes         String?

  plant   Plant     @relation(fields: [plantId], references: [id])
  plantId String
  bed     GardenBed @relation(fields: [bedId], references: [id])
  bedId   String

  squares     BedSquare[]
  harvestLogs HarvestLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PLANT DATABASE ─────────────────────────

model PlantFamily {
  id         String  @id @default(uuid())
  name       String  @unique   // e.g. "Solanaceae"
  commonName String?           // e.g. "Nightshade family"
  plants     Plant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plant {
  id               String         @id @default(uuid())
  name             String
  scientificName   String?
  variety          String?
  category         PlantCategory
  lifecycle        PlantLifecycle
  hardinessZoneMin String?
  hardinessZoneMax String?

  family   PlantFamily? @relation(fields: [familyId], references: [id])
  familyId String?

  sunRequirement    SunRequirement?
  waterNeed         WaterNeed?
  seasonType        SeasonType?
  daysToMaturity    Int?
  daysToGermination Int?
  plantDepthInches  Float?
  spacingInches     Float?
  rowSpacingInches  Float?
  plantHeightInches Float?

  startIndoorWeeks     Int?
  transplantWeeks      Int?
  directSowWeeks       Int?
  harvestRelativeWeeks Int?

  plantsPerSqFt Int?
  sqftColor     String?

  permLayer            PermacultureLayer?
  isNitrogenFixer      Boolean @default(false)
  isDynamicAccumulator Boolean @default(false)
  isEdible             Boolean @default(true)
  isMedicinal          Boolean @default(false)
  attractsPollinators  Boolean @default(false)
  deerResistant        Boolean @default(false)

  dataSource   PlantDataSource @default(SEED)
  isUserEdited Boolean         @default(false)
  externalSlug String?
  lastSyncedAt DateTime?

  // Soil & environment (from Trefle)
  phMin              Float?
  phMax              Float?
  soilNutriments     Int?     // 0-10 scale
  soilHumidity       Int?     // 0-10 scale
  soilTexture        Int?     // 0-10 scale
  soilSalinity       Int?     // 0-10 scale
  atmosphericHumidity Int?    // 0-10 scale
  precipitationMin   Int?     // mm/year
  precipitationMax   Int?     // mm/year
  minRootDepthCm     Float?   // minimum root depth in cm
  maxHeightCm        Float?   // maximum height in cm

  // Growth timing (comma-separated month abbreviations: "mar,apr,may")
  growthMonths String?
  bloomMonths  String?
  fruitMonths  String?

  // Growth characteristics
  growthRate         String?  // "slow", "moderate", "rapid"
  ligneousType       String?  // "liana", "subshrub", "shrub", "tree", "parasite"
  growthForm         String?  // landscape growth form
  growthHabit        String?  // general plant architecture
  shapeAndOrientation String? // predominant plant shape
  toxicity           String?  // "none", "low", "medium", "high"

  // Appearance
  flowerColor       String?  // comma-separated: "yellow,white"
  flowerConspicuous Boolean? // whether flowers are showy
  foliageColor      String?  // comma-separated: "green"
  foliageTexture    String?  // "fine", "medium", "coarse"
  fruitColor        String?  // comma-separated: "red,orange"
  fruitConspicuous  Boolean? // whether fruit is visible
  fruitShape        String?  // fruit shape
  seedPersistence   Boolean? // persistent fruit/seed on plant
  isEvergreen       Boolean  @default(false)

  // Edible details
  edibleParts String? // comma-separated: "fruit,leaves,roots"

  notes    String?
  imageUrl String?

  displayPhoto   Photo?   @relation("PlantDisplayPhoto", fields: [displayPhotoId], references: [id])
  displayPhotoId String?  @unique

  plantings      Planting[]
  companionsA    CompanionPlant[] @relation("CompanionA")
  companionsB    CompanionPlant[] @relation("CompanionB")
  seedInventory  SeedInventory[]
  seedStartLogs  SeedStartLog[]
  harvestLogs    HarvestLog[]
  calendarEvents CalendarEvent[]
  photos         Photo[]          @relation("PlantPhotos")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlantCategory {
  VEGETABLE
  FRUIT
  TREE
  SHRUB
  HERB
  COVER_CROP
  FLOWER
  GRASS
}

enum PlantLifecycle {
  ANNUAL
  BIENNIAL
  PERENNIAL
}

enum SunRequirement {
  FULL_SUN
  PARTIAL_SUN
  PARTIAL_SHADE
  FULL_SHADE
}

enum WaterNeed {
  LOW
  MODERATE
  HIGH
}

enum SeasonType {
  COOL
  WARM
}

enum PermacultureLayer {
  CANOPY
  UNDERSTORY
  SHRUB
  HERBACEOUS
  GROUND_COVER
  VINE
  ROOT
  FUNGAL
}

enum PlantDataSource {
  SEED
  TREFLE
  USER
}

model CompanionPlant {
  id    String        @id @default(uuid())
  type  CompanionType
  notes String?

  plantA   Plant  @relation("CompanionA", fields: [plantAId], references: [id])
  plantAId String
  plantB   Plant  @relation("CompanionB", fields: [plantBId], references: [id])
  plantBId String

  @@unique([plantAId, plantBId])
}

enum CompanionType {
  BENEFICIAL
  HARMFUL
  NEUTRAL
}

// ─── CALENDAR & TASKS ───────────────────────

model CalendarEvent {
  id            String            @id @default(uuid())
  title         String
  description   String?
  eventType     CalendarEventType
  date          String
  endDate       String?
  allDay        Boolean @default(true)

  autoGenerated Boolean @default(false)
  generationKey String? @unique
  isUserEdited  Boolean @default(false)

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String
  plant      Plant?   @relation(fields: [plantId], references: [id])
  plantId    String?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CalendarEventType {
  SEED_START_INDOOR
  SEED_START_OUTDOOR
  TRANSPLANT
  HARVEST_START
  HARVEST_END
  PRUNING
  FERTILIZE
  COMPOST
  ANIMAL_CARE
  WATER_SYSTEM
  MAINTENANCE
  CUSTOM
}

model Task {
  id          String         @id @default(uuid())
  title       String
  description String?
  status      TaskStatus     @default(PENDING)
  priority    TaskPriority   @default(MEDIUM)
  dueDate     String?
  completedAt DateTime?
  recurrence  TaskRecurrence @default(NONE)
  notes       String?

  generationKey String? @unique
  isUserEdited  Boolean @default(false)

  assignee   User     @relation(fields: [assigneeId], references: [id])
  assigneeId String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id])
  calendarEventId String?

  photos Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskRecurrence {
  NONE
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  SEASONAL
  YEARLY
}

// ─── ANIMALS ────────────────────────────────

model AnimalGroup {
  id         String     @id @default(uuid())
  name       String
  animalType AnimalType
  notes      String?

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  animals Animal[]
  eggLogs EggLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AnimalType {
  CHICKEN
  DUCK
  GOOSE
  TURKEY
  GOAT
  SHEEP
  PIG
  COW
  RABBIT
  BEE
  OTHER
}

model Animal {
  id           String  @id @default(uuid())
  name         String?
  breed        String?
  dateOfBirth  String?
  dateAcquired String?
  isActive     Boolean @default(true)
  notes        String?

  group   AnimalGroup @relation(fields: [groupId], references: [id])
  groupId String

  healthRecords AnimalHealthRecord[]
  photos        Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnimalHealthRecord {
  id          String @id @default(uuid())
  date        String
  description String
  treatment   String?
  notes       String?

  animal   Animal @relation(fields: [animalId], references: [id])
  animalId String

  createdAt DateTime @default(now())
}

model EggLog {
  id    String @id @default(uuid())
  date  String
  count Int
  notes String?

  group   AnimalGroup @relation(fields: [groupId], references: [id])
  groupId String

  createdAt DateTime @default(now())
}

// ─── WATER SYSTEMS ──────────────────────────

model WaterSystem {
  id              String          @id @default(uuid())
  name            String
  sourceType      WaterSourceType
  capacityGallons Float?
  notes           String?

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  logs WaterLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WaterSourceType {
  RAINWATER
  RIVER_PUMP
  WELL
  MUNICIPAL
}

model WaterLog {
  id           String @id @default(uuid())
  date         String
  levelGallons Float?
  usageGallons Float?
  notes        String?

  system   WaterSystem @relation(fields: [systemId], references: [id])
  systemId String

  createdAt DateTime @default(now())
}

// ─── COMPOSTING ─────────────────────────────

model CompostBin {
  id           String @id @default(uuid())
  name         String
  type         String?
  capacityCuFt Float?
  notes        String?

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  logs CompostLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompostLog {
  id             String @id @default(uuid())
  date           String
  action         String
  tempFahrenheit Float?
  notes          String?

  bin   CompostBin @relation(fields: [binId], references: [id])
  binId String

  createdAt DateTime @default(now())
}

// ─── INVENTORY ──────────────────────────────

model SeedInventory {
  id              String  @id @default(uuid())
  quantity        Int?
  unit            String?
  supplier        String?
  yearPurchased   Int?
  expiryYear      Int?
  lotNumber       String?
  germinationRate Int?
  storageLocation String?
  seedSource      String?    // PURCHASED | SAVED | TRADED | GIFTED
  notes           String?

  plant      Plant    @relation(fields: [plantId], references: [id])
  plantId    String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  startLogs SeedStartLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeedStartLog {
  id               String   @id @default(uuid())
  date             String   // YYYY-MM-DD
  cellsStarted     Int
  cellsSprouted    Int?
  sproutedDate     String?  // YYYY-MM-DD
  transplantedDate String?  // YYYY-MM-DD
  medium           String?
  location         String?
  heatMat          Boolean  @default(false)
  lightHours       Int?
  notes            String?

  seedInventory   SeedInventory @relation(fields: [seedInventoryId], references: [id])
  seedInventoryId String
  plant           Plant         @relation(fields: [plantId], references: [id])
  plantId         String
  property        Property      @relation(fields: [propertyId], references: [id])
  propertyId      String
  user            User          @relation(fields: [userId], references: [id])
  userId          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id        String            @id @default(uuid())
  name      String
  category  InventoryCategory
  quantity  Int?
  unit      String?
  location  String?
  condition String?
  notes     String?

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  photos Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InventoryCategory {
  SEED
  TOOL
  AMENDMENT
  FEED
  SUPPLY
}

// ─── HARVEST TRACKING ───────────────────────

model HarvestLog {
  id          String  @id @default(uuid())
  date        String
  quantityLbs Float?
  notes       String?

  planting   Planting? @relation(fields: [plantingId], references: [id])
  plantingId String?
  plant      Plant?    @relation(fields: [plantId], references: [id])
  plantId    String?
  property   Property  @relation(fields: [propertyId], references: [id])
  propertyId String
  user       User      @relation(fields: [userId], references: [id])
  userId     String

  photos Photo[]

  createdAt DateTime @default(now())
}

// ─── SOIL HEALTH ────────────────────────────

model SoilTest {
  id            String     @id @default(uuid())
  date          String     // YYYY-MM-DD
  ph            Float?
  nitrogen      Float?
  phosphorus    Float?
  potassium     Float?
  organicMatter Float?
  texture       String?
  notes         String?
  bed           GardenBed? @relation(fields: [bedId], references: [id])
  bedId         String?
  property      Property   @relation(fields: [propertyId], references: [id])
  propertyId    String
  user          User       @relation(fields: [userId], references: [id])
  userId        String
  createdAt     DateTime   @default(now())
}

model AmendmentLog {
  id           String     @id @default(uuid())
  date         String     // YYYY-MM-DD
  amendment    String
  quantityLbs  Float?
  areaSqFt     Float?
  notes        String?
  bed          GardenBed? @relation(fields: [bedId], references: [id])
  bedId        String?
  property     Property   @relation(fields: [propertyId], references: [id])
  propertyId   String
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime   @default(now())
}

// ─── JOURNAL ────────────────────────────────

model JournalEntry {
  id           String   @id @default(uuid())
  date         String   // YYYY-MM-DD
  content      String
  weatherNotes String?
  mood         String?  // great | good | okay | tough
  property     Property @relation(fields: [propertyId], references: [id])
  propertyId   String
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  photos       Photo[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([propertyId, date, userId])
}

// ─── PHOTOS ─────────────────────────────────

model Photo {
  id      String  @id @default(uuid())
  key     String
  caption String?
  takenAt String?

  property     Property       @relation(fields: [propertyId], references: [id])
  propertyId   String
  zone         PropertyZone?  @relation(fields: [zoneId], references: [id])
  zoneId       String?
  bed          GardenBed?     @relation(fields: [bedId], references: [id])
  bedId        String?
  task         Task?          @relation(fields: [taskId], references: [id])
  taskId       String?
  animal       Animal?        @relation(fields: [animalId], references: [id])
  animalId     String?
  harvestLog   HarvestLog?    @relation(fields: [harvestLogId], references: [id])
  harvestLogId String?
  inventory       InventoryItem? @relation(fields: [inventoryId], references: [id])
  inventoryId     String?
  journalEntry    JournalEntry?  @relation(fields: [journalEntryId], references: [id])
  journalEntryId  String?
  plant           Plant?   @relation("PlantPhotos", fields: [plantId], references: [id])
  plantId         String?
  displayForPlant Plant?   @relation("PlantDisplayPhoto")

  createdAt DateTime @default(now())
}

// ─── APP SETTINGS & HOME ASSISTANT ──────────

model AppSettings {
  id    String @id @default(uuid())
  key   String @unique
  value String

  updatedAt DateTime @updatedAt
}

model HaSensor {
  id         String  @id @default(uuid())
  entityId   String  @unique
  name       String
  sensorType String
  unit       String?
  zoneId     String?
  isActive   Boolean @default(true)

  readings HaSensorReading[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HaSensorReading {
  id           String   @id @default(uuid())
  value        String
  numericValue Float?
  isRollup     Boolean  @default(false)
  recordedAt   DateTime @default(now())

  sensor   HaSensor @relation(fields: [sensorId], references: [id])
  sensorId String

  @@index([sensorId, recordedAt])
}
