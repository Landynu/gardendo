# Database (auto-set if using `wasp start db`)
DATABASE_URL="postgresql://user:password@localhost:5432/gardendo"

# Auth
JWT_SECRET="change-me-to-a-random-secret"

# Railway Object Storage (S3-compatible) — needed for photo uploads
# S3_ENDPOINT="https://your-bucket.railway.app"
# S3_BUCKET="gardendo"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
# S3_REGION="us-east-1"
